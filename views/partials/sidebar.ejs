<aside class="sidebar">

    <div class="logo">
        <h2>📒 WorkJournal</h2>
    </div>

    <ul class="menu">

        <% navigation.forEach(item=> { %>

            <li class="<%= currentPath === item.url ? 'active' : '' %>">

                <a href="<%= item.url %>">

                    <i class="<%= item.icon %>"></i>

                    <span>
                        <%= item.title %>
                    </span>

                </a>

            </li>

            <% }) %>



    </ul>

</aside>