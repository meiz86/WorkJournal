<aside class="sidebar">

    <div class="logo">
        <h2>📒 WorkJournal</h2>
    </div>

    <ul class="menu">

        <% navigation.forEach(item => { %>

            <li class="<%= currentPath === item.url ? 'active' : '' %>">

                <a href="<%= item.url %>">

                    <i class="<%= item.icon %>"></i>

                    <span><%= item.title %></span>

                </a>

            </li>

        <% }) %>

        <% if (user && user.role === "Admin") { %>

            <li class="<%= currentPath.startsWith('/admin') ? 'active' : '' %>">

                <a href="/admin">

                    <i class="fas fa-users-cog"></i>

                    <span>Administration</span>

                </a>

            </li>

        <% } %>

    </ul>

</aside>