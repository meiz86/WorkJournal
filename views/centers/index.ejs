<div class="page-header">

    <div class="page-title">
        <h1>
            <i class="fa-solid fa-building"></i>
            Centers
        </h1>

        <p>
            Manage control centers and their assigned stations.
        </p>
    </div>

    <a href="/centers/new" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i>
        New Center
    </a>

</div>

<div class="panel">

    <table class="dashboard-table">

        <thead>

            <tr>
                <th>Center</th>
                <th>Acronym</th>
                <th>Status</th>
                <th style="width:160px;">Actions</th>
            </tr>

        </thead>

        <tbody>

            <% if (centers.length===0) { %>

                <tr>
                    <td colspan="4" style="text-align:center;padding:30px;">
                        <i class="fa-solid fa-building-circle-xmark fa-2x"></i>
                        <br><br>
                        No centers found.
                    </td>
                </tr>

                <% } %>

                    <% centers.forEach(center=> { %>

                        <tr>

                            <td>

                                <a href="/centers/<%= center.id %>">
                                    <strong>
                                        <%= center.name %>
                                    </strong>
                                </a>

                            </td>

                            <td>
                                <%= center.acronym %>
                            </td>

                            <td>

                                <% if (center.is_active) { %>

                                    <span class="badge badge-success">
                                        <i class="fa-solid fa-circle-check"></i>
                                        Active
                                    </span>

                                    <% } else { %>

                                        <span class="badge badge-danger">
                                            <i class="fa-solid fa-circle-xmark"></i>
                                            Inactive
                                        </span>

                                        <% } %>

                            </td>

                            <td>

                                <a href="/centers/<%= center.id %>" class="btn btn-info btn-sm" title="View">

                                    <i class="fa-solid fa-eye"></i>

                                </a>

                                <a href="/centers/<%= center.id %>/edit" class="btn btn-primary btn-sm" title="Edit">

                                    <i class="fa-solid fa-pen"></i>

                                </a>

                                <a href="/centers/<%= center.id %>/delete" class="btn btn-danger btn-sm" title="Delete"
                                    onclick="return confirm('Delete this center?')">

                                    <i class="fa-solid fa-trash"></i>

                                </a>

                            </td>

                        </tr>

                        <% }) %>

        </tbody>

    </table>

</div>