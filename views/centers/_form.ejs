<div class="form-card">

    <form action="<%= action %>" method="POST">

        <div class="form-group">

            <label>Center Name</label>

            <input type="text" name="name" value="<%= center ? center.name : '' %>" required>

        </div>

        <div class="form-group">

            <label>Acronym</label>

            <input type="text" name="acronym" value="<%= center ? center.acronym : '' %>" required>

        </div>

        <div class="form-group">

            <label>Details</label>

            <textarea name="details" rows="5"><%= center ? center.details : '' %></textarea>

        </div>

        <div class="form-actions">

            <button class="btn btn-primary" type="submit">

                <i class="fa-solid fa-floppy-disk"></i>

                Save Center

            </button>

            <a href="/centers" class="btn btn-secondary">

                Cancel

            </a>

        </div>

    </form>

</div>