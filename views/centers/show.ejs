<h1>
    <%= center.name %>
</h1>

<p>
Acronym:
<%= center.acronym || "-" %>
</p>

<hr>

<h3>
Stations
</h3>


<% if(stations.length === 0){ %>

<p>
No stations assigned.
</p>


<% } else { %>


<ul>

<% stations.forEach(station=>{ %>

<li>

<strong>
<%= station.name %>
</strong>

<br>

Protocol:

<%= station.protocol || "-" %>


</li>


<% }) %>

</ul>


<% } %>