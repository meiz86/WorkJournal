<div class="page-header">

    <div class="page-title">

        <h1>
            <i class="fa-solid fa-building"></i>
            <%= center.name %>
        </h1>

        <p>
            <%= center.acronym %>
        </p>

    </div>

    <div class="header-actions">

        <a href="/centers" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i>
            Back
        </a>

        <a href="/centers/<%= center.id %>/edit" class="btn btn-primary">
            <i class="fa-solid fa-pen"></i>
            Edit
        </a>

    </div>

</div>


<!-- =========================
     Center Information
========================= -->

<div class="panel">

    <div class="panel-header">
        <h2>Center Information</h2>
    </div>

    <table class="dashboard-table">

        <tbody>

            <tr>
                <th style="width:180px;">Name</th>
                <td>
                    <%= center.name %>
                </td>
            </tr>

            <tr>
                <th>Acronym</th>
                <td>
                    <%= center.acronym %>
                </td>
            </tr>

            <tr>
                <th>Status</th>

                <td>

                    <% if(center.is_active){ %>

                        <span class="badge badge-success">
                            Active
                        </span>

                        <% }else{ %>

                            <span class="badge badge-danger">
                                Inactive
                            </span>

                            <% } %>

                </td>

            </tr>

            <tr>

                <th>Details</th>

                <td>

                    <% if(center.details){ %>

                        <%= center.details %>

                            <% }else{ %>

                                <span class="text-muted">No details.</span>

                                <% } %>

                </td>

            </tr>

        </tbody>

    </table>

</div>


<!-- =========================
     Stations
========================= -->

<div class="panel">

    <div class="panel-header">

        <h2>Assigned Stations</h2>

        <a href="/centers/<%= center.id %>/stations" class="btn btn-primary btn-sm">

            <i class="fa-solid fa-plus"></i>
            Assign Station

        </a>

    </div>

    <% if(stations.length===0){ %>

        <div style="padding:25px;text-align:center;">

            No stations assigned.

        </div>

        <% }else{ %>

            <table class="dashboard-table">

                <thead>

                    <tr>
                        <th>Name</th>
                        <th>Protocol</th>
                    </tr>

                </thead>

                <tbody>

                    <% stations.forEach(station=>{ %>

                        <tr>

                            <td>

                                <a href="/stations/<%= station.id %>">

                                    <%= station.name %>

                                </a>

                            </td>

                            <td>

                                <%= station.protocol || "-" %>

                            </td>

                        </tr>

                        <% }) %>

                </tbody>

            </table>

            <% } %>

</div>


<!-- =========================
     Hardware
========================= -->

<div class="panel">

    <div class="panel-header">

        <h2>Hardware</h2>

        <a href="/centers/<%= center.id %>/hardware/new" class="btn btn-primary btn-sm">

            <i class="fa-solid fa-plus"></i>
            Add Hardware

        </a>

    </div>

    <% if(hardware.length===0){ %>

        <div style="padding:25px;text-align:center;">

            No hardware registered.

        </div>

        <% }else{ %>

            <table class="dashboard-table">

                <thead>

                    <tr>
                        <th>Type</th>
                        <th>Brand</th>
                        <th>Model</th>
                        <th>Qty</th>
                        <th>Status</th>
                    </tr>

                </thead>

                <tbody>

                    <% hardware.forEach(item=>{ %>

                        <tr>

                            <td>
                                <%= item.type %>
                            </td>

                            <td>
                                <%= item.brand || "-" %>
                            </td>

                            <td>
                                <%= item.model || "-" %>
                            </td>

                            <td>
                                <%= item.quantity %>
                            </td>

                            <td>
                                <%= item.status %>
                            </td>

                        </tr>

                        <% }) %>

                </tbody>

            </table>

            <% } %>

</div>