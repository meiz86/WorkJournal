<div class="page-header">

    <h1>Monthly Report</h1>

</div>

<form method="GET" action="/reports/monthly" class="filter-bar">

    <input type="month" name="month" value="<%= month %>">

    <button class="btn btn-primary">
        Generate
    </button>

</form>

<div class="stats-grid">

    <div class="card">

        <h3>Total Days</h3>

        <h1>
            <%= report.length %>
        </h1>

    </div>

    <div class="card">

        <h3>Total Hours</h3>

        <h1>

            <%= (report.reduce((t, r)=> t + (r.minutes || 0), 0) / 60).toFixed(1) %>

        </h1>

    </div>

</div>

<div class="card chart-card">

    <h3>Hours Worked This Month</h3>

    <canvas id="monthlyChart"></canvas>

</div>

<div class="panel">

    <table class="dashboard-table">

        <thead>

            <tr>

                <th>Date</th>
                <th>Activities</th>
                <th>Hours</th>
                <th>Completed</th>
                <th>Pending</th>

            </tr>

        </thead>

        <tbody>

            <% if (report.length===0) { %>

                <tr>

                    <td colspan="5">

                        No data available for this month.

                    </td>

                </tr>

                <% } else { %>

                    <% report.forEach(day=> { %>

                        <tr>

                            <td>
                                <%= day.date %>
                            </td>

                            <td>
                                <%= day.activities %>
                            </td>

                            <td>
                                <%= ((day.minutes || 0) / 60).toFixed(1) %>
                            </td>

                            <td>
                                <%= day.completed %>
                            </td>

                            <td>
                                <%= day.pending %>
                            </td>

                        </tr>

                        <% }) %>

                            <% } %>

        </tbody>

    </table>

</div>

<script>

    window.monthlyData = <% - JSON.stringify(report) %>;

</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/monthlyReport.js"></script>