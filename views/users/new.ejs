<div class="page-header">

    <h1>New User</h1>

</div>


<div class="panel">

    <form action="/users/new" method="POST">


        <div class="form-group">

            <label>Name</label>

            <input
                type="text"
                name="name"
                class="form-control"
                required>

        </div>


        <div class="form-group">

            <label>Email</label>

            <input
                type="email"
                name="email"
                class="form-control"
                required>

        </div>


        <div class="form-group">

            <label>Password</label>

            <input
                type="password"
                name="password"
                class="form-control"
                required>

        </div>


        <div class="form-group">

            <label>Role</label>

            <select
                name="role_id"
                class="form-control"
                required>


                <option value="">
                    Select Role
                </option>


                <% roles.forEach(role => { %>

                    <option value="<%= role.id %>">

                        <%= role.name %>

                    </option>

                <% }) %>


            </select>

        </div>


        <button class="btn btn-primary">

            Create User

        </button>


    </form>

</div>