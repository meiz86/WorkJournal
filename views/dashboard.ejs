<h1>Dashboard</h1>

<div class="dashboard-grid">

    <div class="card">

        <h3>Total Activities</h3>

        <h1><%= stats.totalActivities || 0 %></h1>

    </div>

    <div class="card">

        <h3>Today's Activities</h3>

        <h1><%= stats.todayActivities || 0 %></h1>

    </div>

    <div class="card">

        <h3>Total Hours</h3>

        <h1>

            <%= ((stats.totalMinutes || 0) / 60).toFixed(1) %>

        </h1>

    </div>

    <div class="card">

        <h3>This Month</h3>

        <h1><%= stats.totalActivities || 0 %></h1>

    </div>

</div>