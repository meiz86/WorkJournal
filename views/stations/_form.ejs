<div class="form-card">
    <form action="<%= action %>" method="POST">
        <div class="form-group">
            <label>Station Name</label>

            <input type="text" name="name" value="<%= station ? station.name : '' %>" required />
        </div>

        <div class="form-group">
            <label>Connection Protocol</label>

            <input type="text" name="protocol" placeholder="IEC104, DNP3, Modbus..."
                value="<%= station ? station.protocol : '' %>" />
        </div>

        <div class="form-group">
            <label>Notes</label>

            <textarea name="notes" rows="5"><%= station ? station.notes : '' %></textarea>
        </div>

        <div class="form-actions">
            <button class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk"></i>
                Save Station
            </button>

            <a href="/stations" class="btn btn-secondary"> Cancel </a>
        </div>
    </form>
</div>