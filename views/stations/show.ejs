<div class="page-header">
  <div class="page-title">
    <h1>
      <i class="fa-solid fa-tower-cell"></i>
      <%= station.name %>
    </h1>

    <p>Station Details</p>
  </div>

  <div class="header-actions">
    <a href="/stations" class="btn btn-secondary">
      <i class="fa-solid fa-arrow-left"></i>
      Back
    </a>

    <a href="/stations/<%= station.id %>/edit" class="btn btn-primary">
      <i class="fa-solid fa-pen"></i>
      Edit
    </a>
  </div>
</div>

<!-- =========================
     Station Information
========================= -->

<div class="panel">
  <div class="panel-header">
    <h2>Station Information</h2>
  </div>

  <table class="dashboard-table">
    <tbody>
      <tr>
        <th style="width: 220px">Station Name</th>

        <td><%= station.name %></td>
      </tr>

      <tr>
        <th>Center</th>

        <td>
          <a href="/centers/<%= station.center_id %>">
            <%= station.center_name %>
          </a>
        </td>
      </tr>

      <tr>
        <th>Protocol</th>

        <td>
          <span > <%= station.protocol %> </span>
        </td>
      </tr>
      <tr>
        <th>Media</th>

        <td>
          <span > <%= station.media %> </span>
        </td>
      </tr>

      <tr>
        <th>Notes</th>

        <td><%= station.notes || "No notes." %></td>
      </tr>
    </tbody>
  </table>
</div>
