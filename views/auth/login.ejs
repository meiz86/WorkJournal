<div class="auth-card">

    <div class="auth-logo">
        📒
        <h1>WorkJournal</h1>
    </div>


    <h2>Login</h2>


    <form method="POST" action="/login">

        <div class="form-group">

            <label>Email</label>

            <input 
                type="email"
                name="email"
                required
            >

        </div>


        <div class="form-group">

            <label>Password</label>

            <input 
                type="password"
                name="password"
                required
            >

        </div>


        <button class="btn btn-primary auth-btn">
            Login
        </button>


    </form>


    <p class="auth-link">

        Don't have an account?

        <a href="/register">
            Register
        </a>

    </p>


</div>