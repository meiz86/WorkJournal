```ejs
<div class="form-card">

    <h2>Edit Activity</h2>

    <form action="/activities/<%= activity.id %>/edit" method="POST">

        <div class="form-group">
            <label>Date</label>
            <input
                type="date"
                name="date"
                value="<%= activity.date %>"
                required>
        </div>

        <div class="form-group">

            <label>Project</label>

            <select name="project_id" required>

                <option value="">-- Select Project --</option>

                <% projects.forEach(project => { %>

                    <option
                        value="<%= project.id %>"
                        <%= Number(activity.project_id) === Number(project.id) ? "selected" : "" %>>

                        <%= project.name %>

                    </option>

                <% }) %>

            </select>

        </div>

        <div class="form-group">

            <label>Department</label>

            <select name="department_id" required>

                <option value="">-- Select Department --</option>

                <% departments.forEach(department => { %>

                    <option
                        value="<%= department.id %>"
                        <%= Number(activity.department_id) === Number(department.id) ? "selected" : "" %>>

                        <%= department.name %>

                    </option>

                <% }) %>

            </select>

        </div>

        <div class="form-group">
            <label>Activity</label>
            <input
                type="text"
                name="activity"
                value="<%= activity.activity %>"
                required>
        </div>

        <div class="form-group">
            <label>Description</label>

            <textarea
                name="description"
                rows="5"><%= activity.description || "" %></textarea>

        </div>

        <div class="form-group">
            <label>Duration (minutes)</label>

            <input
                type="number"
                name="duration"
                min="0"
                value="<%= activity.duration %>">

        </div>

        <div class="form-group">

            <label>Status</label>

            <select name="status">

                <% statuses.forEach(status => { %>

                    <option
                        value="<%= status %>"
                        <%= activity.status === status ? "selected" : "" %>>

                        <%= status %>

                    </option>

                <% }) %>

            </select>

        </div>

        <div style="display:flex; gap:10px; margin-top:20px;">

            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk"></i>
                Update Activity
            </button>

            <a href="/activities" class="btn btn-secondary">
                Cancel
            </a>

        </div>

    </form>

</div>
```
