<div class="page-header">

    <div class="page-title">

        <h1>

            <i class="fa-solid fa-clipboard-list"></i>

            Activities

        </h1>

        <p>

            Manage your daily work activities

        </p>

    </div>

    <a
        href="/activities/new"
        class="btn btn-primary">

        <i class="fa-solid fa-plus"></i>

        New Activity

    </a>

</div>



<form method="GET" action="/activities">

    <div class="card">
    <input type="text" name="search" placeholder="Search..." value="<%= filters.search || '' %>">
  

    <select name="status">

        <option value="All">All</option>

        <% statuses.forEach(status=> { %>

            <option value="<%= status %>" <%=filters.status===status ? "selected" : "" %>>

                <%= status %>

            </option>

            <% }) %>

    </select>

    <button type="submit">
        Search
    </button>

    <a href="/activities">
        Clear
    </a>
      </div>    

</form>

<br>

<br>
<table border="1" cellpadding="8" class="table">

    <tr>
        <th>ID</th>
        <th>Date</th>
        <th>Project</th>
        <th>Department</th>
        <th>Activity</th>
        <th>Duration</th>
        <th>Status</th>
    </tr>

    <% activities.forEach(activity=> { %>

        <tr>

            <td>
                <%= activity.id %>
            </td>

            <td>
                <%= activity.date %>
            </td>

            <td>
                <%= activity.project %>
            </td>

            <td>
                <%= activity.department %>
            </td>

            <td>
                <%= activity.activity %>
            </td>

          <%

const h=Math.floor(activity.duration/60);

const m=activity.duration%60;

%>

<td>

<i class="fa-regular fa-clock"></i>

<%= h>0 ? h+"h ":"" %><%= m %>m

</td>

          <td>

<%

let badge="badge-warning";

if(activity.status==="Completed")
badge="badge-success";

if(activity.status==="In Progress")
badge="badge-primary";

%>

<span class="badge <%= badge %>">

<%= activity.status %>

</span>

</td>

        </tr>

        <% }) %>

</table>