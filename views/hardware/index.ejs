<div class="page-header">

    <div class="page-title">

        <h1>
            <i class="fa-solid fa-server"></i>
            <%= center.name %> Hardware
        </h1>

        <p>
            Hardware inventory
        </p>

    </div>

    <a href="/centers/<%= center.id %>/hardware/new" class="btn btn-primary">

        <i class="fa-solid fa-plus"></i>

        Add Hardware

    </a>

</div>

<table class="table">

    <thead>

        <tr>

            <th>Type</th>

            <th>Brand</th>

            <th>Model</th>

            <th>Qty</th>

            <th>Status</th>

            <th></th>

        </tr>

    </thead>

    <tbody>

        <% if(hardware.length===0){ %>

            <tr>

                <td colspan="6">

                    No hardware has been added.

                </td>

            </tr>

            <% } %>

                <% hardware.forEach(item=>{ %>

                    <tr>

                        <td>
                            <%= item.type %>
                        </td>

                        <td>
                            <%= item.brand %>
                        </td>

                        <td>
                            <%= item.model %>
                        </td>

                        <td>
                            <%= item.quantity %>
                        </td>

                        <td>
                            <%= item.status %>
                        </td>

                        <td>

                            <a class="btn btn-secondary" href="/centers/<%= center.id %>/hardware/<%= item.id %>/edit">

                                Edit

                            </a>

                            <form action="/centers/<%= center.id %>/hardware/<%= item.id %>/delete" method="POST"
                                style="display:inline;">

                                <button class="btn btn-danger" onclick="return confirm('Delete this hardware?')">

                                    Delete

                                </button>

                            </form>

                        </td>

                    </tr>

                    <% }) %>

    </tbody>

</table>