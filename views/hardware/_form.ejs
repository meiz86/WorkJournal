<div class="form-card">

    <form action="<%= action %>" method="POST">

        <div class="form-group">

            <label>Type</label>

            <select name="type" required>

                <% hardwareTypes.forEach(type=>{ %>

                    <option value="<%= type %>" <%=item && item.type===type ? "selected" :"" %>>

                        <%= type %>

                    </option>

                    <% }) %>

            </select>

        </div>

        <div class="form-group">

            <label>Brand</label>

            <input type="text" name="brand" value="<%= item ? item.brand : '' %>">

        </div>

        <div class="form-group">

            <label>Model</label>

            <input type="text" name="model" value="<%= item ? item.model : '' %>">

        </div>

        <div class="form-group">

            <label>Quantity</label>

            <input type="number" min="1" name="quantity" value="<%= item ? item.quantity : 1 %>">

        </div>

        <div class="form-group">

            <label>Serial Number</label>

            <input type="text" name="serial_number" value="<%= item ? item.serial_number : '' %>">

        </div>

        <div class="form-group">

            <label>IP Address</label>

            <input type="text" name="ip_address" value="<%= item ? item.ip_address : '' %>">

        </div>

        <div class="form-group">

            <label>Status</label>

            <select name="status">

                <% statuses.forEach(status=>{ %>

                    <option value="<%= status %>" <%=item && item.status===status ? "selected" :"" %>>

                        <%= status %>

                    </option>

                    <% }) %>

            </select>

        </div>

        <div class="form-group">

            <label>Notes</label>

            <textarea name="notes" rows="5"><%= item ? item.notes : '' %></textarea>

        </div>

        <div class="form-actions">

            <button class="btn btn-primary">

                Save

            </button>

            <a href="/centers/<%= center.id %>/hardware" class="btn btn-secondary">

                Cancel

            </a>

        </div>

    </form>

</div>